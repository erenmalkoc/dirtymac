    "A menu bar utility that locks your keyboard so you can clean it — without typing nonsense or launching apps." : {
      "comment" : "Onboarding step 1 body.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Ein Menüleisten-Tool, das deine Tastatur sperrt, damit du sie reinigen kannst – ohne Unsinn zu tippen oder Apps zu starten." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "A menu bar utility that locks your keyboard so you can clean it — without typing nonsense or launching apps." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Una utilidad de la barra de menús que bloquea el teclado para que puedas limpiarlo, sin escribir tonterías ni abrir apps." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Un utilitaire de la barre des menus qui verrouille votre clavier pour que vous puissiez le nettoyer, sans taper n'importe quoi ni lancer d'apps." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Un'utility nella barra dei menu che blocca la tastiera così puoi pulirla, senza digitare cose a caso o avviare app." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "メニューバーからキーボードをロックし、無駄な入力やアプリの起動なしに掃除できるユーティリティです。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "메뉴 막대에서 키보드를 잠가, 엉뚱한 입력이나 앱 실행 없이 청소할 수 있게 해 주는 유틸리티입니다." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Um utilitário da barra de menus que bloqueia o teclado para você limpá-lo — sem digitar bobagens nem abrir apps." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Утилита в строке меню, которая блокирует клавиатуру, чтобы вы могли её почистить — без случайного ввода и запуска приложений." } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Klavyenizi kilitleyip, saçma tuşlara basmadan veya uygulama açmadan temizlemenizi sağlayan bir menü çubuğu aracı." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "一个菜单栏小工具，锁定键盘以便清洁，不会输入乱码或误开应用。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "一個選單列小工具，鎖定鍵盤以便清潔，不會輸入亂碼或誤開 App。" } }
      }
    },
    "dirtymac lives in your menu bar, up here." : {
      "comment" : "Onboarding step 1 hint pointing at the menu bar. Keep 'dirtymac' untranslated.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac wohnt hier oben in deiner Menüleiste." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac lives in your menu bar, up here." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac vive aquí arriba, en la barra de menús." } },
