    },
    "Click the button to release." : {
      "comment" : "Caption below the headline when keyboard is locked.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Zum Entsperren auf die Taste klicken." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Click the button to release." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Haz clic en el botón para liberar." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Cliquer sur le bouton pour déverrouiller." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Fai clic sul pulsante per sbloccare." } },
