    "Grant Accessibility Access" : {
      "comment" : "Onboarding step 2 title.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bedienungshilfen-Zugriff erlauben" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Grant Accessibility Access" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Conceder acceso a Accesibilidad" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Autoriser l'accès à l'Accessibilité" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Concedi accesso all'Accessibilità" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "アクセシビリティへのアクセスを許可" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "손쉬운 사용 권한 허용" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Conceder acesso à Acessibilidade" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Разрешить доступ к универсальному доступу" } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Erişilebilirlik İzni Ver" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "授予辅助功能权限" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "授予輔助使用權限" } }
      }
    },
    "dirtymac needs Accessibility access to intercept keyboard events while you clean. Nothing is recorded, logged, or sent anywhere." : {
      "comment" : "Onboarding step 2 body. Keep 'dirtymac' untranslated.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac benötigt Bedienungshilfen-Zugriff, um Tastaturereignisse während der Reinigung abzufangen. Nichts wird aufgezeichnet, protokolliert oder gesendet." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac needs Accessibility access to intercept keyboard events while you clean. Nothing is recorded, logged, or sent anywhere." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac necesita acceso a Accesibilidad para interceptar eventos del teclado mientras limpias. No se graba, registra ni envía nada." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac a besoin de l'accès à l'Accessibilité pour intercepter les événements clavier pendant le nettoyage. Rien n'est enregistré, journalisé ni envoyé." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac richiede l'accesso all'Accessibilità per intercettare gli eventi della tastiera durante la pulizia. Niente viene registrato, salvato o inviato." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac は掃除中にキーボード入力を遮断するためにアクセシビリティ権限が必要です。記録・保存・送信は一切行いません。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac이 청소하는 동안 키보드 입력을 차단하려면 손쉬운 사용 권한이 필요합니다. 어떤 것도 기록·저장·전송하지 않습니다." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O dirtymac precisa de acesso à Acessibilidade para interceptar eventos do teclado enquanto você limpa. Nada é gravado, registrado ou enviado." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac нужен доступ к универсальному доступу, чтобы перехватывать события клавиатуры во время очистки. Ничего не записывается, не логируется и не отправляется." } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac, sen temizlerken klavye olaylarını engellemek için Erişilebilirlik iznine ihtiyaç duyar. Hiçbir şey kaydedilmez, loglanmaz veya gönderilmez." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac 需要辅助功能权限以在清洁时拦截键盘事件。不会记录、保存或发送任何内容。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac 需要輔助使用權限以在清潔時攔截鍵盤事件。不會記錄、儲存或傳送任何內容。" } }
      }
    },
