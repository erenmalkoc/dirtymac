    "Mouse and trackpad stay enabled." : {
      "comment" : "Caption below the headline when keyboard is unlocked.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Maus und Trackpad bleiben aktiv." } },
