    },
    "Accessibility Access Required" : {
      "comment" : "Title shown when the user has not granted Accessibility permission.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Bedienungshilfen-Zugriff erforderlich" } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "Accessibility Access Required" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Se requiere acceso a Accesibilidad" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Accès à l’Accessibilité requis" } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "Accesso all’Accessibilità richiesto" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "アクセシビリティ権限が必要です" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "손쉬운 사용 권한 필요" } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "Acesso à Acessibilidade necessário" } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "Требуется доступ к Универсальному доступу" } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "Erişilebilirlik İzni Gerekli" } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "需要辅助功能权限" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "需要輔助使用權限" } }
      }
    },
    "dirtymac needs permission to intercept keyboard events while you clean." : {
      "comment" : "Body text on the permission prompt explaining why Accessibility access is needed.",
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac benötigt die Berechtigung, Tastaturereignisse während der Reinigung abzufangen." } },
        "en" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac needs permission to intercept keyboard events while you clean." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac necesita permiso para interceptar eventos del teclado mientras limpias." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac a besoin de l’autorisation d’intercepter les événements clavier pendant le nettoyage." } },
        "it" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac richiede il permesso di intercettare gli eventi della tastiera durante la pulizia." } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac はクリーニング中にキーボード入力を遮断するための権限が必要です。" } },
        "ko" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac이(가) 청소하는 동안 키보드 입력을 차단하려면 권한이 필요합니다." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O dirtymac precisa de permissão para interceptar eventos do teclado enquanto você limpa." } },
        "ru" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac требуется разрешение для перехвата событий клавиатуры во время очистки." } },
        "tr" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac, sen temizlerken klavye olaylarını engelleyebilmek için izne ihtiyaç duyar." } },
        "zh-Hans" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac 需要权限以在清洁时拦截键盘事件。" } },
        "zh-Hant" : { "stringUnit" : { "state" : "translated", "value" : "dirtymac 需要權限以在清潔時攔截鍵盤事件。" } }
      }
    },
