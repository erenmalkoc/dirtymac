        "ko" : { "stringUnit" : { "state" : "translated", "value" : "마우스와 트랙패드는 계속 사용할 수 있습니다." } },
        "pt-BR" : { "stringUnit" : { "state" : "translated", "value" : "O mouse e o trackpad continuam ativos." } },
